qa", "relation_name": "\"dwh_sm2\".\"main\".\"fact\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-30T02:05:55.187734Z", "completed_at": "2026-04-30T02:05:55.213021Z"}, {"name": "execute", "started_at": "2026-04-30T02:05:55.213539Z", "completed_at": "2026-04-30T02:05:55.213549Z"}], "thread_id": "Thread-7 (worker)", "execution_time": 0.027017831802368164, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.dwh_sm2.fact_indoor_humidity", "compiled": true, "compiled_code": "with source as (\n    select * from read_csv('./gdrive/all_sensors_merged.csv')\n),\n\nmapped as (\n    select\n        source.Datetime as \"time\", --noqa\n        mapping.location,\n        'humidity_indoor' as data_key,\n        source.\"Relative_Humidity(%)\" as data_value --noqa\n    from source\n    inner join \"dwh_sm2\".\"main\".\"mapping_indoor\" as mapping --noqa\n        on source.location = mapping.sensor\n    where source.datetime is not null\n),\n\nparams as (\n    select\n        date_trunc( --noqa\n            'month', now()) - interval (b.history - 1 --noqa\n            ) month as start_ts --noqa\n    from \"dwh_sm2\".\"main\".\"mapping_sources\" as b\n    where b.file_nm = 'fact_indoor_humidity.csv'\n),\n\nfinal as (\n    select\n        time,\n        location,\n        data_key,\n        data_value\n    from mapped\n    union distinct\n    select *\n    from read_csv('./gdrive/fact_indoor_humidity.csv')\n)\n\nselect *\nfrom final\nwhere time >= (select max(start_ts) from params) --noqa", "relation_name": "\"dwh_sm2\".\"main\".\"fact_indoor_humidity\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-30T02:05:55.193408Z", "completed_at": "2026-04-30T02:05:55.214426Z"}, {"name": "execute", "started_at": "2026-04-30T02:05:55.214949Z", "completed_at": "2026-04-30T02:05:55.214956Z"}], "thread_id": "Thread-8 (worker)", "execution_time": 0.02279877662658