, "compiled": true, "compiled_code": "with source as ( --noqa\n    select cast(columns(*) as varchar) from read_csv('./gdrive/merged.csv')\n),\n\nunpivoted as (\n    unpivot source --noqa\n    on columns(* exclude (date))\n    into\n    name data_key_original\n    value data_value\n),\n\nmapped as (\n    select\n        unpivoted.date as \"time\", --noqa\n        mapping.location,\n        mapping.data_key,\n        unpivoted.data_value\n    from unpivoted\n    inner join \"dwh_sm2\".\"main\".\"mapping\" as mapping --noqa\n        on unpivoted.data_key_original = mapping.data_key_original\n    where unpivoted.date is not null\n),\n\nparams as (\n    select\n        date_trunc( --noqa\n            'month', now()) - interval (b.history - 1 --noqa\n            ) month as start_ts --noqa\n    from \"dwh_sm2\".\"main\".\"mapping_sources\" as b\n    where b.file_nm = 'fact.csv'\n),\n\nfinal as (\n    select\n        cast(time as timestamp) as time, --noqa\n        location,\n        data_key,\n        data_value\n    from mapped\n    union distinct\n    select * from read_csv('./gdrive/fact.csv')\n)\n\nselect *\nfrom final\nwhere time >= (select max(start_ts) from params) --noqa", "relation_name": "\"dwh_sm2\".\"main\".\"fact\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-10T02:36:07.771548Z", "completed_at": "2026-06-10T02:36:07.792005Z"}, {"name": "execute", "started_at": "2026-06-10T02:36:07.793653Z", "completed_at": "2026-06-10T02:36:07.793664Z"}], "thread_id": "Thread-10 (worker)", "execution_time": 0.025687694549560547, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.dwh_sm2.not_null_fact_indoor_humidity_time.40897f2842", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect time\nfrom \"dwh_sm2\".\"main\".\"fact_indoor_humidity\"\nwhere time is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "